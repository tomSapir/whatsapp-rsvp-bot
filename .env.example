# Copy this file to `.env` and fill in the real values.
# `.env` is gitignored — never commit secrets.

# --- WhatsApp Business Cloud API (Meta) ---
# From your Meta app → WhatsApp product. See PLAN §10 / STEPS.md M0.
WHATSAPP_ACCESS_TOKEN=
PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
# A value you choose; Meta echoes it back during webhook verification (GET /webhook).
WEBHOOK_VERIFY_TOKEN=
# Graph API version used for sending. PLAN §7 targets v21.0.
GRAPH_API_VERSION=v21.0

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Database ---
# SQLite file path (gitignored). Relative to the repo root.
DB_PATH=data/app.sqlite3

# --- Reminders ---
# Re-send the invite to silent Invitations after this many days (N),
# up to REMINDER_MAX_COUNT times, never past the event date. See PLAN §6.
REMINDER_DELAY_DAYS=3
REMINDER_MAX_COUNT=2
